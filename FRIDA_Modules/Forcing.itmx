					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>ktN2O/yr</units>
			</aux>
			<aux name="Mass of the Atmosphere 1" access="input">
				<eqn>5135200000000000000</eqn>
				<units>kilogram</units>
			</aux>
			<aux name="Molecular Weight of Air 1" access="input">
				<eqn>28.97</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="UNIT fraction to ppm" access="input">
				<eqn>1000000</eqn>
				<units>ppm</units>
			</aux>
			<aux name="UNIT ppm to ppb 1" access="input">
				<eqn>1000</eqn>
				<units>ppb/ppm</units>
			</aux>
			<aux name="N2O Baseline emissions" access="input">
				<eqn>0.08602230754</eqn>
				<units>ktN2O/yr</units>
			</aux>
			<aux name="UNIT ktN2O to MtN2O" access="input">
				<eqn>0.001</eqn>
				<units>MtN2O/ktN2O</units>
			</aux>
			<aux name="selected climate case" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<flow name="N2O emissions">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Total_N2O_Emissions</eqn>
				<units>ktN2O/yr</units>
			</flow>
			<stock name="Cumulative N2O emissions">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Initial_Cumulative_N2O_emissions</eqn>
				<inflow>N2O_emissions</inflow>
				<units>KtN2O</units>
			</stock>
			<stock name="N2O in atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Initial_N2O_in_atmosphere</eqn>
				<inflow>N2O_into_atmosphere</inflow>
				<outflow>N2O_out_of_atmosphere</outflow>
				<units>ktN2O</units>
			</stock>
			<flow name="N2O into atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Total_N2O_Emissions - N2O_Baseline_emissions</eqn>
				<units>ktN2O/yr</units>
			</flow>
			<flow name="N2O out of atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>N2O_in_atmosphere/(Baseline_N2O_Lifetime*Scale_factor_for_N2O_lifetime)</eqn>
				<non_negative/>
				<units>ktN2O/yr</units>
			</flow>
		</variables>

	<model name="Ozone_Forcing">
		<variables>
			<aux name="Reduction in Ozone Effective Radiative\nForcing per unit\ntemperature change">
				<doc>${No Sensi}
</doc>
				<eqn>-0.037</eqn>
				<units>W/metre^2/K</units>
			</aux>
			<aux name="Ozone Effective\nRadiative Forcing" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ozone_Effective_Radiative_Forcing_without_Temperature_effect + Reduction_in_Ozone_Effective_Radiative_Forcing_per_unit_temperature_change*Surface_Temperature</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Surface Temperature" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<units>K</units>

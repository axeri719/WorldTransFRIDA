			<aux name="Baseline VOC emissions" access="input">
				<eqn>60.02182622</eqn>
				<units>Mt VOC/yr</units>
			</aux>
			<aux name="Baseline CO emissions" access="input">
				<eqn>348.52735878</eqn>
				<units>Mt CO/yr</units>
			</aux>
			<aux name="Ozone forcing from emissions">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ozone_forcing_per_unit_VOC_emissions_change[selected_climate_case_1[Run]]*(DELAY(VOC_emissions[Run] - Baseline_VOC_emissions,  0.5)) + Ozone_forcing_per_unit_NOx_emissions_change[selected_climate_case_1[Run]]*(DELAY(Total_NOx_emissions - Baseline_NOx_Emissions_1,  0.5)) + Ozone_forcing_per_unit_CO_emissions_change[selected_climate_case_1[Run]]*(DELAY(CO_emissions[Run] - Baseline_CO_emissions,  0.5))</eqn>
				<units>W/metre^2</units>
			</aux>
			<aux name="Ozone Effective Radiative Forcing\nwithout Temperature effect">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Ozone_forcing_from_concentrations[Run] + Ozone_forcing_from_emissions[Run])</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="selected climate case 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Ozone forcing from Montreal gases\nequivalent effective\nstratospheric chlorine">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Montreal_gases_equivalent_effective_stratospheric_chlorine - Montreal_gases_equivalent_effective_stratospheric_chlorine_1750)*Ozone_forcing_per_unit_Montreal_gases_equivalent_effective_stratospheric_chlorine_concentration_change[selected_climate_case_1[Run]]</eqn>
				<units>W/metre^2</units>
			</aux>
			<aux name="Ozone forcing per unit Montreal gases\nequivalent effective stratospheric\nchlorine concentration change">

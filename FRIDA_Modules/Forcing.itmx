			<aux name="Ozone forcing from concentrations">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Atmospheric_CH4_Concentration - Atmospheric_CH4_Concentration_1750)*Ozone_forcing_per_unit_CH4_concentration_change[selected_climate_case_1[Run]] + (Atmospheric_N2O_Concentration - Atmospheric_N2O_Concentration_1750)*Ozone_forcing_per_unit_N2O_concentration_change[selected_climate_case_1[Run]] + Ozone_forcing_from_Montreal_gases_equivalent_effective_stratospheric_chlorine[Run]</eqn>
				<units>W/metre^2</units>
			</aux>

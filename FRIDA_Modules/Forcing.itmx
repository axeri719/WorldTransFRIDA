	</model>
	<model name="Minor_GHGs_Forcing">
		<variables>
			<aux name="Montreal Gases Effective\nRadiative Forcing">
				<doc>${No Sensi}
</doc>
				<eqn>NAN</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="HFC134a emissions" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>kt/year</units>
			</aux>
			<aux name="Forcing per unit\nHFC134a eq concentrations">
				<doc>${No Sensi}
</doc>
				<eqn>0.16714</eqn>
				<units>(W/(metre^2))/(ppb)</units>
			</aux>
			<aux name="Baseline HFC134a eq Lifetime">
				<doc>${No Sensi}
</doc>
				<eqn>14</eqn>
				<units>years</units>
			</aux>
			<aux name="Initial HFC134a\neq in atmosphere">
				<doc>${No Sensi}
</doc>
				<eqn>415.994738802</eqn>
				<units>kt</units>
			</aux>
			<aux name="Molecular Weight of HFC134a eq">
				<doc>${No Sensi}
</doc>
				<eqn>102.03</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="Atmospheric HFC134a\neq Concentration" access="output">
				<doc>${Explanatory Variable}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(HFC134a_eq_in_atmosphere/(( Mass_of_the_Atmosphere/(UNIT_kt_to_kg*UNIT_fraction_to_ppm))*Molecular_Weight_of_HFC134a_eq/Molecular_Weight_of_Air))*UNIT_ppm_to_ppt + Atmospheric_HFC134a_eq_Concentration_1750</eqn>
				<units>ppt</units>
			</aux>
			<aux name="Mass of the Atmosphere" access="input">
				<eqn>5135200000000000000</eqn>
				<units>kilogram</units>
			</aux>
			<aux name="UNIT fraction to ppm" access="input">
				<eqn>1000000</eqn>
				<units>ppm</units>
			</aux>
			<aux name="Molecular Weight of Air" access="input">
				<eqn>28.97</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="UNIT ppm to ppt" access="input">
				<eqn>1000000</eqn>
				<units>ppt/ppm</units>
			</aux>
			<aux name="UNIT kt to kg" access="input">
				<eqn>1000000</eqn>
				<units>kg/kt</units>
			</aux>
			<aux name="HFC134a eq Effective\nRadiative Forcing">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Forcing_per_unit_HFC134a_eq_concentrations*(Atmospheric_HFC134a_eq_Concentration - Atmospheric_HFC134a_eq_Concentration_1750)*UNIT_ppt_to_ppb</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Minor GHGs Effective\nRadiative Forcing" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>

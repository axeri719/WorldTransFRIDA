	<model name="Forcing">
		<variables>
			<aux name="Effective Radiative Forcing from\nthe CH4 effect on\nStratospheric H2O" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Stratospheric_H2O_Effective_Radiative_Forcing_per_CH4_Effective_Radiative_Forcing * CH4_Effective_Radiative_Forcing)*Calibration_scaling_of_Stratospheric_H2O_forcing[selected_climate_case[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Ozone Effective\nRadiative Forcing" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ozone_Effective_Radiative_Forcing_without_Temperature_effect + Reduction_in_Ozone_Effective_Radiative_Forcing_per_unit_temperature_change*Surface_Temperature</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Calibration scaling\nof Black Carbon on Snow forcing" access="input">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Effective_Radiative_Forcing_of_Black_Carbon_on_Snow_per_unit_SO2_Emissions*(DELAY(Total_SO2_Emissions_1,  0.5) - SO2_Baseline_Emissions) + Effective_Radiative_Forcing_of_Black_Carbon_on_Snow_per_unit_CO2_AFOLU_Emissions*(DELAY(CO2_emissions_2,  0.5)-CO2_AFOLU_Baseline_Emissions)*UNIT_MtCO2_to_GtCO2)*scale_BC_Snow[selected_climate_case[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="CO2 Effective Radiative Forcing" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="CH4 Effective Radiative Forcing" access="output" throughput="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="N2O Effective Radiative Forcing" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Effective Radiative\nForcing from Natural Sources" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Effective Radiative Forcing from\nAerosols" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<module name="Ozone Forcing" isee:label="">
				<format scale_by="auto"/>
				<connect to="CH4_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine" from="Ozone_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine"/>
				<connect2 to="CH4_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine" from="Ozone_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine"/>
				<connect to="CH4_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine_1750" from="Ozone_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine_1750"/>
				<connect2 to="CH4_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine_1750" from="Ozone_Forcing.Montreal_gases_equivalent_effective_stratospheric_chlorine_1750"/>
				<connect to="Forcing.Ozone_Effective_Radiative_Forcing" from="Ozone_Forcing.Ozone_Effective_Radiative_Forcing"/>
				<connect2 to="Ozone_Effective_Radiative_Forcing" from="Ozone_Forcing.Ozone_Effective_Radiative_Forcing"/>
				<connect to="Ozone_Forcing.Atmospheric_CH4_Concentration_1750" from="CH4_Forcing.Atmospheric_CH4_Concentration_1750"/>
				<connect2 to="Ozone_Forcing.Atmospheric_CH4_Concentration_1750" from="CH4_Forcing.Atmospheric_CH4_Concentration_1750"/>
				<connect to="Ozone_Forcing.Atmospheric_CH4_Concentration" from="CH4_Forcing.Atmospheric_CH4_Concentration"/>
				<connect2 to="Ozone_Forcing.Atmospheric_CH4_Concentration" from="CH4_Forcing.Atmospheric_CH4_Concentration"/>
				<connect to="Ozone_Forcing.Atmospheric_N2O_Concentration_1750" from="N2O_Forcing.Atmospheric_N2O_Concentration_1750"/>
				<connect2 to="Ozone_Forcing.Atmospheric_N2O_Concentration_1750" from="N2O_Forcing.Atmospheric_N2O_Concentration_1750"/>
				<connect to="Ozone_Forcing.Atmospheric_N2O_Concentration" from="N2O_Forcing.Atmospheric_N2O_Concentration"/>
				<connect2 to="Ozone_Forcing.Atmospheric_N2O_Concentration" from="N2O_Forcing.Atmospheric_N2O_Concentration"/>
				<connect to="Ozone_Forcing.Baseline_CO_emissions" from="Emissions.Baseline_CO_Emissions"/>
				<connect2 to="Ozone_Forcing.Baseline_CO_emissions" from="Emissions.Baseline_CO_Emissions"/>
				<connect to="Ozone_Forcing.Baseline_NOx_Emissions_1" from="Emissions.Baseline_NOx_Emissions"/>
				<connect2 to="Ozone_Forcing.Baseline_NOx_Emissions_1" from="Emissions.Baseline_NOx_Emissions"/>
				<connect to="Ozone_Forcing.Baseline_VOC_emissions" from="Emissions.Baseline_VOC_Emissions"/>
				<connect2 to="Ozone_Forcing.Baseline_VOC_emissions" from="Emissions.Baseline_VOC_Emissions"/>
				<connect to="Ozone_Forcing.CO_emissions" from="Emissions.CO_Emissions"/>
				<connect2 to="Ozone_Forcing.CO_emissions" from="Emissions.CO_Emissions"/>
				<connect to="Ozone_Forcing.selected_climate_case_1" from="Climate_Units.selected_climate_case"/>
				<connect2 to="Ozone_Forcing.selected_climate_case_1" from="Climate_Units.selected_climate_case"/>
				<connect to="Ozone_Forcing.Surface_Temperature" from="Energy_Balance_Model.Surface_Temperature"/>
				<connect2 to="Ozone_Forcing.Surface_Temperature" from="Energy_Balance_Model.Surface_Temperature"/>
				<connect to="Ozone_Forcing.Total_NOx_emissions" from="Emissions.Total_NOx_Emissions"/>
				<connect2 to="Ozone_Forcing.Total_NOx_emissions" from="Emissions.Total_NOx_Emissions"/>
				<connect to="Ozone_Forcing.VOC_emissions" from="Emissions.VOC_Emissions"/>
				<connect2 to="Ozone_Forcing.VOC_emissions" from="Emissions.VOC_Emissions"/>
			</module>
			<module name="Aerosol Forcing" isee:label="">
				<format scale_by="auto"/>
				<connect to="Forcing.Effective_Radiative_Forcing_from_Aerosols" from="Aerosol_Forcing.Effective_Radiative_Forcing_from_Aerosols"/>
				<connect2 to="Effective_Radiative_Forcing_from_Aerosols" from="Aerosol_Forcing.Effective_Radiative_Forcing_from_Aerosols"/>
				<connect to="Aerosol_Forcing.selected_climate_case" from="Climate_Units.selected_climate_case"/>
				<connect2 to="Aerosol_Forcing.selected_climate_case" from="Climate_Units.selected_climate_case"/>
				<connect to="Aerosol_Forcing.SO2_Baseline_Emissions" from="Emissions.SO2_Baseline_Emissions"/>
				<connect2 to="Aerosol_Forcing.SO2_Baseline_Emissions" from="Emissions.SO2_Baseline_Emissions"/>
				<connect to="Aerosol_Forcing.Total_SO2_Emissions" from="Emissions.Total_SO2_Emissions"/>
				<connect2 to="Aerosol_Forcing.Total_SO2_Emissions" from="Emissions.Total_SO2_Emissions"/>
			</module>
			<module name="Stratospheric Water Vapour Forcing" isee:label="">
				<format scale_by="auto"/>
				<connect to="Forcing.Effective_Radiative_Forcing_from_the_CH4_effect_on_Stratospheric_H2O" from="Stratospheric_Water_Vapour_Forcing.Effective_Radiative_Forcing_from_the_CH4_effect_on_Stratospheric_H2O"/>
				<connect2 to="Effective_Radiative_Forcing_from_the_CH4_effect_on_Stratospheric_H2O" from="Stratospheric_Water_Vapour_Forcing.Effective_Radiative_Forcing_from_the_CH4_effect_on_Stratospheric_H2O"/>
				<connect to="Stratospheric_Water_Vapour_Forcing.CH4_Effective_Radiative_Forcing" from="Forcing.CH4_Effective_Radiative_Forcing"/>
				<connect2 to="Stratospheric_Water_Vapour_Forcing.CH4_Effective_Radiative_Forcing" from="CH4_Effective_Radiative_Forcing"/>
				<connect to="Stratospheric_Water_Vapour_Forcing.selected_climate_case" from="Climate_Units.selected_climate_case"/>
				<connect2 to="Stratospheric_Water_Vapour_Forcing.selected_climate_case" from="Climate_Units.selected_climate_case"/>
			</module>
			<module name="Natural Forcing" isee:label="">
				<format scale_by="auto"/>
				<connect to="Forcing.Effective_Radiative_Forcing_from_Natural_Sources" from="Natural_Forcing.Effective_Radiative_Forcing_from_Natural_Sources"/>
				<connect2 to="Effective_Radiative_Forcing_from_Natural_Sources" from="Natural_Forcing.Effective_Radiative_Forcing_from_Natural_Sources"/>
				<connect to="Natural_Forcing.selected_climate_case_2" from="Climate_Units.selected_climate_case"/>
				<connect2 to="Natural_Forcing.selected_climate_case_2" from="Climate_Units.selected_climate_case"/>
				<connect to="Natural_Forcing.selected_climate_case_3" from="Climate_Units.selected_climate_case"/>
				<connect2 to="Natural_Forcing.selected_climate_case_3" from="Climate_Units.selected_climate_case"/>
			</module>
			<module name="BC on Snow Forcing" isee:label="">
				<format scale_by="auto"/>
				<connect to="Forcing.Calibration_scaling_of_Black_Carbon_on_Snow_forcing" from="BC_on_Snow_Forcing.Effective_Radiative_Forcing_of_Black_Carbon_on_Snow"/>
				<connect2 to="Calibration_scaling_of_Black_Carbon_on_Snow_forcing" from="BC_on_Snow_Forcing.Effective_Radiative_Forcing_of_Black_Carbon_on_Snow"/>
				<connect to="BC_on_Snow_Forcing.CO2_Emissions_from_Food_and_Land_Use" from="Emissions.CO2_Emissions_from_Food_and_Land_Use"/>
				<connect2 to="BC_on_Snow_Forcing.CO2_Emissions_from_Food_and_Land_Use" from="Emissions.CO2_Emissions_from_Food_and_Land_Use"/>
				<connect to="BC_on_Snow_Forcing.selected_climate_case_1" from="Climate_Units.selected_climate_case"/>
				<connect2 to="BC_on_Snow_Forcing.selected_climate_case_1" from="Climate_Units.selected_climate_case"/>
				<connect to="BC_on_Snow_Forcing.SO2_Baseline_Emissions_1" from="Emissions.SO2_Baseline_Emissions"/>
				<connect2 to="BC_on_Snow_Forcing.SO2_Baseline_Emissions_1" from="Emissions.SO2_Baseline_Emissions"/>
				<connect to="BC_on_Snow_Forcing.Total_SO2_Emissions_1" from="Emissions.Total_SO2_Emissions"/>
				<connect2 to="BC_on_Snow_Forcing.Total_SO2_Emissions_1" from="Emissions.Total_SO2_Emissions"/>
				<connect to="BC_on_Snow_Forcing.UNIT_MtCO2_to_GtCO2_1" from="Climate_Units.UNIT_MtCO2_to_GtCO2"/>
				<connect2 to="BC_on_Snow_Forcing.UNIT_MtCO2_to_GtCO2_1" from="Climate_Units.UNIT_MtCO2_to_GtCO2"/>
			</module>

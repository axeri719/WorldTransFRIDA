			<aux name="Anthropogenic Effective Radiative\nForcing" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CO2_Effective_Radiative_Forcing + CH4_Effective_Radiative_Forcing + N2O_Effective_Radiative_Forcing + Total_Land_use_forcing + Effective_Radiative_Forcing_from_Aerosols + Effective_Radiative_Forcing_from_the_CH4_effect_on_Stratospheric_H2O + Ozone_Effective_Radiative_Forcing + Calibration_scaling_of_Black_Carbon_on_Snow_forcing + Minor_GHGs_Effective_Radiative_Forcing</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Total Effective Radiative\nForcing" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn> Effective_Radiative_Forcing_from_Natural_Sources +  Anthropogenic_Effective_Radiative_Forcing</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Total Land use forcing" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Minor GHGs Effective\nRadiative Forcing" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>W/(metre^2)</units>
			</aux>

				<units>GtC/Year</units>
			</aux>
			<aux name="Atmospheric CO2 growth GtC">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Annual_change_of_atmospheric_CO2*UNIT_MtCO2_to_GtCO2/UNIT_weight_ratio_of_CO2_over_C</eqn>
				<units>GtC/Year</units>
			</aux>

	<model name="CO2_Forcing">
		<variables>
			<aux name="Molecular Weight of CO2">
				<doc>${No Sensi}
</doc>
				<eqn>44.009</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="Atmospheric CO2 Concentration" access="output">
				<doc>${Calibrated Output,Explanatory Variable}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Atmospheric_CO2_mass_anomaly_since_1750*UNIT_MtCO2_to_GtCO2/((Mass_of_the_Atmosphere/(UNIT_fraction_to_ppm*UNIT_GtCO2_to_kg))*(Molecular_Weight_of_CO2/Molecular_Weight_of_Air)) + Atmospheric_CO2_Concentration_1750</eqn>
				<units>ppm</units>
			</aux>
			<aux name="Atmospheric CO2\nConcentration 1750" access="output" isee:autocreated="true">
				<doc>${External Parameter,No Sensi}
</doc>
				<eqn>284.29727</eqn>
				<units>ppm</units>
			</aux>
			<aux name="CO2 forcing adjustment due to\nfast tropospheric feedbacks">
				<doc>${No Sensi}
</doc>
				<eqn>0.05</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="CO2 forcing\nlogarithmic parameter">
				<doc>${No Sensi}
f1 CO2</doc>
				<eqn>4.57</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="CO2 forcing\nsquare root parameter">
				<doc>${No Sensi}
f3 CO2</doc>
				<eqn>0.086</eqn>
				<units>(W/metre^2)/sqrt_ppm</units>
			</aux>
			<aux name="CO2 Effective Radiative Forcing" access="output">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CO2_forcing_logarithmic_parameter*LN(Atmospheric_CO2_Concentration/Atmospheric_CO2_Concentration_1750) + (SQRT(CO2_forcing_square_root_parameter_squared*Atmospheric_CO2_Concentration) - (SQRT(CO2_forcing_square_root_parameter_squared*Atmospheric_CO2_Concentration_1750)))) * (1+CO2_forcing_adjustment_due_to_fast_tropospheric_feedbacks)*Calibration_scaling_of_CO2_forcing[selected_climate_case_1[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="UNIT GtCO2 to kg">
				<doc>${Unit}
</doc>
				<eqn>1000000000000</eqn>
				<units>Kg/GtCO2</units>
			</aux>
			<aux name="CO2 forcing\nsquare root parameter squared">
				<doc>${No Sensi}
</doc>
				<eqn>0.007396</eqn>
				<units>((W/metre^2)^2)/ppm</units>
			</aux>
			<aux name="Calibration scaling\nof CO2 forcing">
				<doc>${External Parameter,No Sensi}
</doc>

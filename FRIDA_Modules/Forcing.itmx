			<stock name="Atmospheric CO2 mass anomaly since 1750" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Initial_Atmospheric_CO2_mass_anomaly_since_1750[selected_climate_case[Run]]</eqn>
				<inflow>Annual_change_of_atmospheric_CO2</inflow>
				<units>MtCO2</units>
			</stock>
			<flow name="Annual change of atmospheric CO2">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>&quot;Total_CO2_Emissions_without_land-use&quot; -direct_air_capture_CO2_Captured- UNIT_weight_ratio_of_CO2_over_C*(Air_sea_co2_flux_1  + Net_land_carbon_flux) / UNIT_MtCO2_to_GtCO2</eqn>
				<units>MtCO2/Year</units>
			</flow>

			<aux name="Warm surface ocean\ncarbon export to intermediate ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Reference_strength_of_biological_carbon_pump_in_low_latitude_ocean[selected_climate_case_3[Run]]</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</aux>
			<aux name="Cold surface ocean\ncarbon export to intermediate ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Reference_strength_of_biological_carbon_pump_in_high_latitude_ocean[selected_climate_case_3[Run]] + High_latitude_carbon_pump_sensitivity_to_global_T_anomaly[selected_climate_case_3[Run]]*Surface_Temperature_Anomaly)*(1.0 - High_latitude_carbon_pump_transfer_efficiency[selected_climate_case_3[Run]])</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</aux>
			<aux name="Cold surface ocean\ncarbon export to\ndeep ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Reference_strength_of_biological_carbon_pump_in_high_latitude_ocean[selected_climate_case_3[Run]] + High_latitude_carbon_pump_sensitivity_to_global_T_anomaly[selected_climate_case_3[Run]]*Surface_Temperature_Anomaly)*High_latitude_carbon_pump_transfer_efficiency[selected_climate_case_3[Run]]</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</aux>
			<flow name="Biological carbon pump C\nexport to the deep ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Cold_surface_ocean_carbon_export_to_deep_ocean</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
			<flow name="Biological carbon pump C\nexport from warm surface to intermediate ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Warm_surface_ocean_carbon_export_to_intermediate_ocean</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
			<flow name="Biological carbon pump C export from cold surface to intermediate ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Cold_surface_ocean_carbon_export_to_intermediate_ocean</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>

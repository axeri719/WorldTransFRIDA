			<aux name="Ocean surface area">
				<doc>${External Parameter,No Sensi}
</doc>
				<eqn>360000000000000</eqn>
				<units>metre^2</units>
			</aux>
			<aux name="Ocean volume">
				<doc>${External Parameter,No Sensi}
</doc>
				<eqn>1360000000000000000</eqn>
				<units>metre^3</units>
			</aux>
			<aux name="Volume of warm surface ocean reservoir">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ocean_surface_area*Warm_surface_ocean_area_fraction*Depth_of_warm_surface_ocean_layer[selected_climate_case]</eqn>
				<format precision="full"/>
				<units>metre^3</units>
			</aux>
			<aux name="Volume of cold surface\nocean reservoir">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ocean_surface_area*(1.0 - Warm_surface_ocean_area_fraction) *Depth_of_cold_surface_ocean_layer[selected_climate_case[Run]]</eqn>
				<format precision="full"/>
				<units>metre^3</units>
			</aux>
			<aux name="Volume of intermediate\nocean reservoir">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ocean_surface_area*Thickness_of_intermediate_ocean_layer[selected_climate_case[Run]]</eqn>
				<format precision="full"/>
				<units>metre^3</units>
			</aux>
			<aux name="Volume of deep ocean reservoir">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ocean_volume-Volume_of_warm_surface_ocean_reservoir-Volume_of_cold_surface_ocean_reservoir-Volume_of_intermediate_ocean_reservoir</eqn>
				<format precision="full"/>
				<units>metre^3</units>
			</aux>
			<aux name="Atmospheric CO2 Concentration" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>ppm</units>
			</aux>
			<aux name="Warm surface\nocean pCO2">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>UNIT_fraction_to_ppm* (warm_surface_ocean_DIC_conentration_unitless/(1.0 + k1_warm/new_hion_warm + k1_warm*k2_warm/new_hion_warm^2)) / kh_warm</eqn>
				<format precision="full"/>
				<units>ppm</units>
			</aux>
			<aux name="Warm surface ocean temperature">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Warm_surface_ocean_reference_temperature+Surface_Temperature_Anomaly*Warm_surface_ocean_temperature_sensitivity_to_global_T_anomaly[selected_climate_case_4]</eqn>
				<format precision="full"/>
				<units>deg C</units>
			</aux>
			<aux name="Surface Temperature Anomaly" access="input">

					<eqn>8.31297071116</eqn>
				</element>
				<units>1</units>
			</aux>
			<aux name="Warm TK">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Warm_surface_ocean_temperature*UNIT_deg_C_to_unitless + UNIT_Kelvin_at_0_deg_C_unitless</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="Cold TK">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Cold_surface_ocean_temperature*UNIT_deg_C_to_unitless + UNIT_Kelvin_at_0_deg_C_unitless</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="bor warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>boron_sensitivity_to_salinity*(Warm_surface_ocean_salinity_unitless/reference_salinity_for_boron_calculation)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="reference salinity for boron calculation">
				<doc>${External Parameter}
</doc>
				<eqn>35</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="bor cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>boron_sensitivity_to_salinity*(Cold_surface_ocean_salinity_unitless/reference_salinity_for_boron_calculation)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="boron sensitivity to salinity">
				<doc>${External Parameter}
</doc>
				<eqn>0.0004325</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="kh warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXP(9345.17/Warm_TK - 60.2409 + 23.3585*LN(Warm_TK/100.0) + Warm_surface_ocean_salinity_unitless * (0.023517 - 2.3656e-4*Warm_TK + 0.0047036e-4*Warm_TK^2) )</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="kh cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXP(9345.17/Cold_TK - 60.2409 + 23.3585*LN(Cold_TK/100.0) + Cold_surface_ocean_salinity_unitless * (0.023517 - 2.3656e-4*Cold_TK + 0.0047036e-4*Cold_TK^2) )</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="k1 warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>10^(-(3633.86/Warm_TK - 61.2172 + 9.6777*LN(Warm_TK) - 0.011555*Warm_surface_ocean_salinity_unitless + 1.152e-4*Warm_surface_ocean_salinity_unitless^2))</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="k1 cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>10^(-(3633.86/Cold_TK - 61.2172 + 9.6777*LN(Cold_TK) - 0.011555*Cold_surface_ocean_salinity_unitless + 1.152e-4*Cold_surface_ocean_salinity_unitless^2))</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="k2 warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>10^(-(471.78/Warm_TK + 25.9290 - 3.16967*LN(Warm_TK) - 0.01781*Warm_surface_ocean_salinity_unitless + 1.122e-4*Warm_surface_ocean_salinity_unitless^2))</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="k2 cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>10^(-(471.78/Cold_TK + 25.9290 - 3.16967*LN(Cold_TK) - 0.01781*Cold_surface_ocean_salinity_unitless + 1.122e-4*Cold_surface_ocean_salinity_unitless^2))</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="kb warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXP((-8966.90 - 2890.51 * SQRT(Warm_surface_ocean_salinity_unitless) - 77.942 * Warm_surface_ocean_salinity_unitless + 1.728 * Warm_surface_ocean_salinity_unitless^1.5 - 0.0996*Warm_surface_ocean_salinity_unitless^2) / Warm_TK + (148.0248 + 137.194 * SQRT(Warm_surface_ocean_salinity_unitless) + 1.62142 * Warm_surface_ocean_salinity_unitless) + (-24.4344 - 25.085 * SQRT(Warm_surface_ocean_salinity_unitless) - 0.2474 * Warm_surface_ocean_salinity_unitless) * LN(Warm_TK) + 0.053105 * SQRT(Warm_surface_ocean_salinity_unitless) * Warm_TK)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="kb cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXP((-8966.90 - 2890.51 * SQRT(Cold_surface_ocean_salinity_unitless) - 77.942 * Cold_surface_ocean_salinity_unitless + 1.728 * Cold_surface_ocean_salinity_unitless^1.5 - 0.0996*Cold_surface_ocean_salinity_unitless^2) / Cold_TK + (148.0248 + 137.194 * SQRT(Cold_surface_ocean_salinity_unitless) + 1.62142 * Cold_surface_ocean_salinity_unitless) + (-24.4344 - 25.085 * SQRT(Cold_surface_ocean_salinity_unitless) - 0.2474 * Cold_surface_ocean_salinity_unitless) * LN(Cold_TK) + 0.053105 * SQRT(Cold_surface_ocean_salinity_unitless) * Cold_TK)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="kw warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXP((-13847.26/Warm_TK + 148.96502 - 23.6521 * LN(Warm_TK)) + (118.67/Warm_TK -5.977 +1.0495 * LN(Warm_TK)) * SQRT(Warm_surface_ocean_salinity_unitless) - 0.01615 * Warm_surface_ocean_salinity_unitless )</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="kw cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXP((-13847.26/Cold_TK + 148.96502 - 23.6521 * LN(Cold_TK)) + (118.67/Cold_TK -5.977 +1.0495 * LN(Cold_TK)) * SQRT(Cold_surface_ocean_salinity_unitless) - 0.01615 * Cold_surface_ocean_salinity_unitless )</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="old hion warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>10^(-Warm_surface_ocean_pH)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="bo4hg warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bor_warm*kb_warm/(old_hion_warm+kb_warm)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="fg warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>-bo4hg_warm-(kw_warm/old_hion_warm)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="calkg warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>fg_warm+Warm_surface_ocean_alkalinity_unitless</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="gam warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>warm_surface_ocean_DIC_conentration_unitless/calkg_warm</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="DIC concentration in warm surface layer">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Warm_surface_ocean_carbon_reservoir*UNIT_GtC_to_kmol/Volume_of_warm_surface_ocean_reservoir</eqn>
				<format precision="full"/>
				<units>kmol/metre^3</units>
			</aux>
			<aux name="DIC concentration in cold surface layer">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Cold_surface_ocean_carbon_reservoir*UNIT_GtC_to_kmol_1/Volume_of_cold_surface_ocean_reservoir</eqn>
				<format precision="full"/>
				<units>kmol/metre^3</units>
			</aux>
			<aux name="tmp warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>((1.0 - gam_warm) * k1_warm)^2 - 4.0 * k1_warm*k2_warm*(1.0 - 2.0 * gam_warm)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="concentration unit">
				<doc>${Unit}
</doc>
				<eqn>1</eqn>
				<format precision="full"/>
				<units>kmol/metre^3</units>
			</aux>
			<aux name="warm surface ocean DIC conentration unitless">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>DIC_concentration_in_warm_surface_layer/concentration_unit</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="cold surface ocean DIC concentration unitless">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>DIC_concentration_in_cold_surface_layer/concentration_unit</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="new hion warm">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.5 * (( gam_warm - 1.0) * k1_warm + SQRT(tmp_warm))</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<flow name="Change of warm surface ocean pH">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(-LOG10(new_hion_warm)-Warm_surface_ocean_pH)/Ocean_surface_pH_change_time_scale</eqn>
				<units>1/year</units>
			</flow>
			<aux name="Cold surface\nocean pCO2">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>UNIT_fraction_to_ppm* (cold_surface_ocean_DIC_concentration_unitless/(1.0 + k1_cold/new_hion_cold + k1_cold*k2_cold/new_hion_cold^2)) / kh_cold</eqn>
				<format precision="full"/>
				<units>ppm</units>
			</aux>
			<stock name="Cold surface ocean pH">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Initial_Cold_surface_ocean_pH[selected_climate_case[Run]]</eqn>
				<format precision="full"/>
				<inflow>Change_of_cold_surface_ocean_pH</inflow>
				<units>1</units>
			</stock>
			<aux name="old hion cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>10^(-Cold_surface_ocean_pH)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="bo4hg cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bor_cold*kb_cold/(old_hion_cold+kb_cold)</eqn>
				<format precision="full"/>
				<units>1</units>

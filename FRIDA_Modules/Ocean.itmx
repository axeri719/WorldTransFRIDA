			<aux name="calkg cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>fg_cold+Cold_surface_ocean_alkalinity_unitless</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="gam cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>cold_surface_ocean_DIC_concentration_unitless/calkg_cold</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="tmp cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>((1.0 - gam_cold) * k1_cold)^2 - 4.0 * k1_cold*k2_cold*(1.0 - 2.0 * gam_cold)</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<aux name="new hion cold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.5 * (( gam_cold - 1.0) * k1_cold + SQRT(tmp_cold))</eqn>
				<format precision="full"/>
				<units>1</units>
			</aux>
			<flow name="Change of cold surface ocean pH">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(-LOG10(new_hion_cold)-Cold_surface_ocean_pH)/Ocean_surface_pH_change_time_scale</eqn>
